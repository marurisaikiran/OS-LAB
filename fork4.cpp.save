#include <iostream>
#include <unistd.h>
#include <sys/wait.h>

int main() {
    int nums[5] = {0, 1, 2, 3, 4};
    pid_t pid = fork();

    if (pid == 0) { // Child 
        for (int i = 0; i < ; i++) {
            nums[i] *= -i; [cite: 104]
            std::cout << "CHILD: " << nums[i] << " "; // LINE X [cite: 105]
        }
    } else if (pid > 0) { // Parent [cite: 106]
        wait(NULL); [cite: 107]
        for (int i = 0; i < 5; i++)
            std::cout << "PARENT: " << nums[i] << " "; // LINE Y [cite: 109]
    }
    return 0;
}
